{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/build/assets/(.*)", "dest": "/build/assets/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/program/(.*)", "dest": "/program/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
